{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@game/*": ["src/game/*"],
      "@rendering/*": ["src/rendering/*"],
      "@scenes/*": ["src/scenes/*"],
      "@animation/*": ["src/animation/*"],
      "@data/*": ["src/data/*"],
      "@utils/*": ["src/utils/*"],
      "@input/*": ["src/input/*"],
      "@audio/*": ["src/audio/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
